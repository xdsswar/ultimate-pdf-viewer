# Normalize text files to LF in the repo; check out with the platform default.
* text=auto

# Scripts that MUST keep specific line endings to run, regardless of platform.
gradlew      text eol=lf
*.sh         text eol=lf
*.bat        text eol=crlf
*.cmd        text eol=crlf

# Binary assets — never normalize or diff as text.
*.jar        binary
*.png        binary
*.jpg        binary
*.pdf        binary
*.so         binary
*.dll        binary
*.dylib      binary
*.lib        binary
*.tgz        binary
